{
  "manifest_version": 3,
  "name": "ecoIA — impact IA",
  "short_name": "ecoIA",
  "version": "0.1.0",
  "description": "Estimation locale et transparente des tokens, de l'électricité, de l'eau et du carbone de vos conversations IA.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.mistral.ai/*",
    "https://www.perplexity.ai/*"
  ],
  "action": {
    "default_title": "Afficher ou masquer ecoIA",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content/core.js", "content/chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/core.js", "content/claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/core.js", "content/gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.mistral.ai/*"],
      "js": ["content/core.js", "content/mistral.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": ["content/core.js", "content/perplexity.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}
