{
  "methodologyVersion": "2026-07-18.1",
  "sources": [
    {
      "id": "how-hungry-v6",
      "title": "How Hungry is AI? Benchmarking Energy, Water, and Carbon Footprint of LLM Inference",
      "url": "https://arxiv.org/abs/2505.09598v6",
      "publicationDate": "2025-11-24",
      "accessedDate": "2026-07-18",
      "primary": true,
      "scope": "Operational inference estimates derived from public API performance, inferred hardware, PUE, WUE and grid carbon intensity.",
      "limitations": [
        "The proprietary-model values are modeled estimates, not provider meter readings.",
        "Batch size, hardware, region, cache and hidden reasoning can materially change results.",
        "Scope 3 and full lifecycle impacts are excluded from the OpenAI and Anthropic estimates used here."
      ]
    },
    {
      "id": "google-gemini-median-2025",
      "title": "How much energy does Google’s AI use? We did the math",
      "url": "https://cloud.google.com/blog/products/infrastructure/measuring-the-environmental-impact-of-ai-inference/",
      "publicationDate": "2025-08-21",
      "accessedDate": "2026-07-18",
      "primary": true,
      "scope": "Median Gemini Apps text-generation prompt measured from May 2025 production data, including serving-system overhead.",
      "limitations": [
        "The values describe a median product prompt, not every prompt and not a per-token coefficient.",
        "The claims were not independently verified by a third party.",
        "The model mix and user behavior can change after the May 2025 measurement period."
      ]
    },
    {
      "id": "mistral-lca-2025",
      "title": "Our contribution to a global environmental standard for AI",
      "url": "https://mistral.ai/news/our-contribution-to-a-global-environmental-standard-for-ai/",
      "publicationDate": "2025-07-22",
      "accessedDate": "2026-07-18",
      "primary": true,
      "scope": "Marginal lifecycle impacts of using Le Chat for a 400-token Mistral Large 2 response, excluding the user terminal.",
      "limitations": [
        "The disclosed response has 400 output tokens; its input length is not published.",
        "The result is a first approximation and includes modeled upstream hardware impacts.",
        "No energy-per-response value is disclosed in this publication."
      ]
    }
  ],
